<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Dashboard Mutasi Dana</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/socket.io/socket.io.js"></script>
</head>
<body>
  <div class="admin-shell">
    <aside class="sidebar">
      <div class="brand-mark">DANA</div>
      <h2>Mutasi Realtime</h2>
      <p>Dashboard monitoring transaksi Dana.</p>
      <form method="POST" action="/logout">
        <button class="logout" type="submit">Logout</button>
      </form>
    </aside>

    <main class="main">
      <section class="hero-card">
        <div>
          <span class="kicker">LIVE DASHBOARD</span>
          <h1>Mutasi Dana Realtime</h1>
          <p>Transaksi masuk dari APK helper akan muncul otomatis tanpa reload.</p>
        </div>
        <div class="status-pill" id="socketStatus">Connecting</div>
      </section>

      <section class="stats-grid">
        <div class="stat"><span>Transaksi Hari Ini</span><strong id="todayCount"><%= stats.todayCount %></strong></div>
        <div class="stat"><span>Total Hari Ini</span><strong id="todayTotal">Rp <%= Number(stats.todayTotal).toLocaleString('id-ID') %></strong></div>
        <div class="stat"><span>Device</span><strong><%= stats.deviceCount %></strong></div>
        <div class="stat"><span>Pending Deposit</span><strong><%= stats.pendingCount %></strong></div>
      </section>

      <section class="grid-two">
        <div class="panel">
          <div class="panel-head">
            <h3>Buat Deposit Test</h3>
          </div>
          <form class="inline-form" method="POST" action="/admin/deposit/create">
            <input name="username" placeholder="username" required>
            <input name="amount" placeholder="nominal unik contoh 100123" required>
            <input name="minutes" placeholder="expired menit" value="30">
            <button type="submit">Buat Pending</button>
          </form>
        </div>

        <div class="panel">
          <div class="panel-head"><h3>Device Aktif</h3></div>
          <div id="deviceList" class="device-list">
            <% devices.forEach(d => { %>
              <div class="device-item" data-device="<%= d.device_id %>">
                <strong><%= d.device_id %></strong>
                <span><%= d.status %> · <%= d.provider %></span>
              </div>
            <% }) %>
            <% if (!devices.length) { %><p class="empty">Belum ada device.</p><% } %>
          </div>
        </div>
      </section>

      <section class="panel">
        <div class="panel-head"><h3>Pending Deposit</h3></div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>User</th><th>Nominal</th><th>Status</th><th>Expired</th><th>Aksi</th></tr></thead>
            <tbody id="depositBody">
              <% pendingDeposits.forEach(d => { %>
                <tr>
                  <td><%= d.username %></td>
                  <td>Rp <%= Number(d.amount).toLocaleString('id-ID') %></td>
                  <td><span class="badge pending"><%= d.status %></span></td>
                  <td><%= new Date(d.expired_at).toLocaleString('id-ID') %></td>
                  <td><form method="POST" action="/admin/deposit/<%= d._id %>/reject"><button class="mini danger">Reject</button></form></td>
                </tr>
              <% }) %>
              <% if (!pendingDeposits.length) { %><tr><td colspan="5" class="empty">Belum ada deposit pending.</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </section>

      <section class="panel">
        <div class="panel-head"><h3>Mutasi Masuk</h3></div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Waktu</th><th>Provider</th><th>Nominal</th><th>Pengirim</th><th>Device</th><th>Source</th><th>Status</th></tr></thead>
            <tbody id="trxBody">
              <% transactions.forEach(t => { %>
                <tr>
                  <td><%= new Date(t.createdAt).toLocaleString('id-ID') %></td>
                  <td><%= t.provider %></td>
                  <td>Rp <%= Number(t.amount).toLocaleString('id-ID') %></td>
                  <td><%= t.sender %></td>
                  <td><%= t.device_id %></td>
                  <td><%= t.source %></td>
                  <td><span class="badge"><%= t.status %></span></td>
                </tr>
              <% }) %>
              <% if (!transactions.length) { %><tr><td colspan="7" class="empty">Belum ada transaksi.</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </div>
  <script src="/js/dashboard.js"></script>
</body>
</html>
